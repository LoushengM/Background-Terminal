<Window
    x:Class="Background_Terminal.TerminalWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="TerminalWindow"
    AllowsTransparency="True"
    Background="Transparent"
    Loaded="TerminalWindow_Loaded"
    LocationChanged="TerminalWindow_LocationChanged"
    MouseDown="TerminalWindow_MouseDown"
    ResizeMode="NoResize"
    ShowInTaskbar="False"
    SizeChanged="TerminalWindow_SizeChanged"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True"
    WindowStyle="None"
    mc:Ignorable="d">
    <Grid>
        <TextBox
            x:Name="TerminalData_TextBox"
            AcceptsReturn="True"
            Background="Transparent"
            BorderThickness="0"
            Focusable="False"
            IsReadOnly="True"
            IsReadOnlyCaretVisible="True"
            IsUndoEnabled="False"
            TextWrapping="Wrap"
            TextChanged="TerminalDataTextBox_TextChanged" />
        <TextBox
            x:Name="Input_TextBox"
            VerticalAlignment="Bottom"
            AcceptsTab="False"
            Background="Transparent"
            BorderThickness="0"
            Focusable="False"
            FontFamily="Consolas"
            PreviewMouseDown="InputTextBox_PreviewMouseDown"
            PreviewKeyDown="InputTextBox_PreviewKeyDown" />
    </Grid>
</Window>
